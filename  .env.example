# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nomadstack
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nomadstack

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# External API Keys (Get yours at the provided links)
# WeatherAPI: https://www.weatherapi.com/
WEATHER_API_KEY=your_weather_api_key

# Exchange Rate API: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchange_api_key

# OpenTripMap API: https://opentripmap.io/product
OPEN_TRIP_MAP_KEY=your_opentripmap_key

# Security
SECRET_KEY=your_super_secret_key_change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
